<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="styles.css" type="text/css"?>

<interfaces>
        <interfaz tipo="ethernet">
            <nombre>eth0</nombre>
            <direccion_ip>192.168.10.50</direccion_ip>
            <mascara>255.255.255.0</mascara>
            <estado>up</estado>
            <puerta_enlace>192.168.10.1</puerta_enlace>
        </interfaz>

        <interfaz tipo="wifi">
            <nombre>wlan0</nombre>
            <direccion_ip>10.0.0.15</direccion_ip>
            <mascara>255.255.255.0</mascara>
            <estado>down</estado>
            <puerta_enlace></puerta_enlace>
        </interfaz>

        <interfaz tipo="loopback">
            <nombre>lo0</nombre>
            <direccion_ip>127.0.0.1</direccion_ip>
            <mascara>255.0.0.0</mascara>
            <estado>up</estado>
            <puerta_enlace></puerta_enlace>
        </interfaz>
        
</interfaces>